---
---

<section class="login">

  <div class="login__card">

    <!-- LOGO -->
    <a class="login__logo" href="/" aria-label="SEINA">
      <img
        src="/Identidad/Identidad principal en blanco.png"
        alt="SEINA"
        width="240"
        height="180"
        loading="eager"
      />
    </a>

    <h2 class="login__title">Bienvenido</h2>

    <form class="login__form" id="login-form">

      <div class="field">
        <input
          class="field__input"
          name="email"
          type="email"
          placeholder="Correo"
          autocomplete="email"
          required
        />
      </div>

      <div class="field">
        <input
          class="field__input"
          name="password"
          type="password"
          placeholder="Contraseña"
          autocomplete="current-password"
          required
        />
      </div>

      <div class="login__actions">
       <!-- <button class="login__primary" type="button">
          Registrarse
        </button>-->

        <button class="login__acceder" type="submit">
          Acceder
        </button>
      </div>

      <p class="login__error" id="login-error" role="alert" aria-live="polite"></p>

    </form>

  </div>

</section>

<style>

/* 🔥 GLOBAL FIX (clave para evitar desplazamientos raros) */
* {
  box-sizing: border-box;
}

/* CONTENEDOR GENERAL */
.login {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 24px;
}

/* CARD */
.login__card {
  width: min(400px, 85%);
  text-align: center;
  padding-top:30px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* LOGO */
.login__logo {
  margin-bottom: 10px;
  display: inline-block;
}

/* TITULO */
.login__title {
  margin: 0 0 24px;
  font-size: 48px;
  font-weight: 400;
  color: #fff;
}

/* FORM */
.login__form {
  width: 100%;
  display: flex;
  flex-direction: column;

  gap: 18px;
  align-items: stretch; /* 🔥 clave para alineación perfecta */
}

/* FIELD */
.field {
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* INPUTS */
.field__input {
  width: 100%;
  display: block;

  padding: 12px;
  border-radius: 12px;

  border: 1px solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.95);

  color: #111;
  font-size: 15px;
  outline: none;
}

.field__input::placeholder {
  color: rgba(0, 0, 0, 0.5);
  font-size: 25px;
  font-style: italic;
  letter-spacing: 0.2px;
}

/* BOTONES */
.login__actions {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-top: 12px;
  width: 100%;
}

.login__primary,
.login__acceder {
  flex: 1;
  max-width: 180px;

  padding: 14px 18px;
  border-radius: 19px;
  border: none;
  cursor: pointer;

  font-weight: 800;
  font-size: 15px;
}

/* COLORES */
.login__primary {
  background: #553304;
  color: #fff;
}

.login__acceder {
  background: #f8f1e7;
  color: #0b0f19;
}

/* RESPONSIVE */
@media (max-width: 520px) {
  .login__actions {
    flex-direction: column;
  }

  .login__primary,
  .login__acceder {
    max-width: none;
    width: 100%;
  }
}

</style>

<script type="module">

function getBackendBase() {
  // Asume que el backend corre en el mismo host del front, pero en el puerto 8000
  // Ej: front http://10.10.10.11:4321/ -> backend http://10.10.10.11:8000
  const { hostname, protocol } = window.location;
  return `${protocol}//${hostname}:8000`;
}

const BACKEND_BASE = getBackendBase();



  function $(sel) {
    return document.querySelector(sel);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const form = $('#login-form');
    const btnPrimary = form?.querySelector('.login__primary');
    const btnSubmit = form?.querySelector('button[type="submit"]');
    const errorEl = $('#login-error');

    btnPrimary?.addEventListener('click', () => {
      // Aún no hay registro en la UI: dejamos placeholder
      window.location.href = '/register';
    });

    btnSubmit?.addEventListener('click', async (e) => {
      e.preventDefault();
      if (!form) return;

      const fd = new FormData(form);
      const email = String(fd.get('email') || '').trim();
      const password = String(fd.get('password') || '');

      errorEl && (errorEl.textContent = '');

      try {
        console.log('LOGIN_PAYLOAD', { email, passwordLen: password?.length });

        const res = await fetch(`${BACKEND_BASE}/api/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });

        const data = await res.json().catch(() => null);

        if (!res.ok) {
          const msg = data?.email?.[0] || data?.message || 'Login falló';
          if (errorEl) errorEl.textContent = msg;
          return;
        }

        window.localStorage.setItem('auth_token', data.access_token);
        window.localStorage.setItem('auth_user', JSON.stringify(data.user || {}));


        // redirige a una ruta protegida (ajusta si tienes otra)
        window.location.href = '/';
      } catch (err) {
        if (errorEl) errorEl.textContent = String(err?.message || err);
      }
    });
  });
</script>

