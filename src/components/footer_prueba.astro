<footer class="site-footer">

  <div class="site-footer__inner">

    <!-- LEFT (FAQS) -->
    <div class="site-footer__col">
      <h4 class="site-footer__title">FAQ</h4>

      <a href="/faq#que-es" class="site-footer__link">¿Qué es SEINA?</a>
      <a href="/faq#servicios" class="site-footer__link">¿Qué servicios ofrecen?</a>
      <a href="/faq#tiempos" class="site-footer__link">Tiempos de entrega</a>
      <a href="/faq#contacto" class="site-footer__link">Soporte y contacto</a>
    </div>

    <!-- CENTER (LOGO) -->
    <div class="site-footer__col site-footer__col--brand">
      <a href="/" class="site-footer__logo" aria-label="SEINA">
        <img
          src="/Identidad/Identidad principal (footer)-01.png"
          alt="SEINA"
          width="140"
          height="196"
          loading="lazy"
        />
      </a>

      <p class="site-footer__text">
        Construyendo experiencias digitales modernas y minimalistas.
      </p>
    </div>

    <!-- RIGHT (REDES EN FILA) -->
    <div class="site-footer__col">
      <h4 class="site-footer__title">Redes sociales</h4>

      <div class="site-footer__socials">
        <a href="#" class="site-footer__link">Instagram</a>
        <a href="#" class="site-footer__link">Twitter</a>
        <a href="#" class="site-footer__link">LinkedIn</a>
        <a href="#" class="site-footer__link">GitHub</a>
      </div>
    </div>

  </div>

  <div class="site-footer__bottom">
    <p>© {new Date().getFullYear()} SEINA. Todos los derechos reservados.</p>
  </div>

</footer>

<style>
.site-footer {
  background: #563304;
  color: #fff;
  padding: 80px 20px 30px;
  backdrop-filter: blur(10px);
}

/* CONTENEDOR PRINCIPAL */
.site-footer__inner {
  width: 90%;
  max-width: 1800px;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 80px;

  align-items: start;
  text-align: center;
}

/* COLUMNAS */
.site-footer__col {
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
}

/* LOGO */
.site-footer__logo img {
  display: block;
  width: clamp(140px, 10vw, 240px);
  height: auto;
}

.site-footer__text {
  font-size: clamp(14px, 0.9vw, 18px);
  opacity: 0.8;
  line-height: 1.6;
  max-width: 350px;
}

/* TITULOS */
.site-footer__title {
  font-size: clamp(16px, 1vw, 22px);
  margin-bottom: 10px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  opacity: 0.9;
}

/* LINKS */
.site-footer__link {
  color: rgba(255,255,255,.75);
  text-decoration: none;
  font-size: clamp(14px, 0.9vw, 18px);
  transition: .2s ease;
}

.site-footer__link:hover {
  color: #fff;
  transform: translateX(2px);
}

/* REDES */
.site-footer__socials {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
  justify-content: center;
}

/* BOTTOM */
.site-footer__bottom {
  margin-top: 50px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,.1);

  text-align: center;
  font-size: clamp(12px, 0.8vw, 16px);
  opacity: 0.7;
}

/* RESPONSIVE */
@media (max-width: 768px) {

  .site-footer__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .site-footer__logo img {
    width: 140px;
  }
}
</style>