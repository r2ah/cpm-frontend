---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/footer_prueba.astro';
import AboutUs from '../components/AboutUs.astro';
import Mission from '../components/Mission.astro';
import Vision from '../components/Vision.astro';
---

<Layout title="About">

  <main class="page">

    <!-- HERO -->
    <section class="hero">

      <!-- BACKGROUND -->
      <div class="hero__bg">
        <img
          src="/Imágenes/Imagen de pantalla de inicio-fondo.jpg"
          alt=""
        />
      </div>

      <!-- OVERLAY -->
      <div class="hero__overlay"></div>

      <!-- HEADER -->
      <Header />

    </section>

    <!-- ABOUT -->
    <section id="about">
      <AboutUs />
    </section>

    <!-- MISSION -->
    <section id="mission">
      <Mission />
    </section>

    <!-- VISION -->
    <section id="vision">
      <Vision />
    </section>

    <!-- FOOTER -->
    <Footer />

  </main>

</Layout>

<style>

/* =========================
   PAGE
========================= */

.page {
  width: 100%;
  overflow-x: hidden;
}

/* =========================
   HERO
========================= */

.hero {
  position: relative;
  width: 100%;
  height: 50vh;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 2;
  pointer-events: none;
}

.hero :global(header) {
  position: relative;
  z-index: 3;
}

/* =========================
   ABOUT SUPERPUESTO
========================= */

#about {
  position: relative;
  margin-top: -120px;
  z-index: 10;

  background: white;
  border-radius: 30px 30px 0 0;
}

/* =========================
   RESTO DE SECCIONES
========================= */

#mission,
#vision {
  width: 100%;
}

/* =========================
   RESPONSIVE
========================= */

@media (max-width: 768px) {

  #about {
    margin-top: -80px;
  }

}

</style>