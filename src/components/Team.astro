---
// Team Section
---

<section class="team">
  <div class="team__inner">

    <h2 class="team__title">Equipo de trabajo</h2>

    <div class="team__grid">

      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 1" />
        <h3>Nombre 1</h3>
      </article>

      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 2" />
        <h3>Nombre 2</h3>
      </article>

      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 3" />
        <h3>Nombre 3</h3>
      </article>

      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 4" />
        <h3>Nombre 4</h3>
      </article>

    </div>

  </div>
</section>

<style>
.team {
  width: 100%;
  padding: 100px 0;
  background: #fff;
}

.team__inner {
  width: 90%;
  max-width: 1800px;
  margin: 0 auto;
}

.team__title {
  text-align: center;
  font-size: clamp(42px, 3vw, 72px);
  margin-bottom: 60px;
  color: #111;
}

.team__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
}

.team__card {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.team__card img {
  width: 100%;
  max-width: clamp(220px, 14vw, 320px);
  height: auto;
  aspect-ratio: 220 / 270;
  object-fit: cover;
  border-radius: 18px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.team__card h3 {
  margin: 0;
  font-size: clamp(18px, 1.2vw, 28px);
  color: #222;
}

/* Tablet */
@media (max-width: 900px) {
  .team__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Móvil */
@media (max-width: 500px) {
  .team__grid {
    grid-template-columns: 1fr;
  }

  .team__title {
    font-size: 32px;
  }
}
</style>