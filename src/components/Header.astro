---
import SideMenu from './SideMenu.astro';
import Menu from './Menu.astro';
import ProfileButton from './ProfileButton.astro';
import HamburgerButton from './HamburgerButton.astro';
---

<header class="site-header">

  <div class="site-header__inner">

    <!-- LEFT -->
    <div class="site-header__left">
      <a class="site-header__brand" href="/" aria-label="SEINA">
        <img
          src="/Identidad/Identidad secundaria en blanco (barra superior)-01.png"
          alt="SEINA"
          width="160"
          height="40"
          decoding="async"
          loading="eager"
        />
      </a>
    </div>

    <!-- CENTER -->
    <div class="site-header__center">
      <nav class="site-header__nav" aria-label="Navegación">
        <Menu />
      </nav>
    </div>

    <!-- RIGHT -->
    <div class="site-header__right">
      <div class="site-header__actions">

        <a
          class="site-header__btn site-header__btn--signup"
          id="header-auth-link"
          href="/login"
        >
          <span class="site-header__btn-text" id="header-auth-link-text">Acceder</span>
        </a>

        <div class="site-header__profile" id="site-header-profile" style="display:none; flex-direction:column; align-items:center; gap:4px;">
          <ProfileButton />
          <span id="site-header-user-email" style="font-size:12px; opacity:0.85; margin-top:-2px;"></span>
        </div>

        <div class="site-header__hamburger" id="menu-toggle">
          <HamburgerButton />
        </div>

      </div>
    </div>

  </div>
</header>

<!-- SIDEMENU -->
<nav class="site-header__side-nav" aria-label="Navegación lateral">
  <SideMenu />
</nav>

<style>
/* =========================
   BASE HEADER
========================= */

.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  height:10vh;
  
  background: rgba(91, 91, 99, 0.35);
  backdrop-filter: blur(10px);

  display: flex;
  justify-content: center;
  box-sizing: border-box;
}

/* =========================
   CONTAINER PRINCIPAL
========================= */

.site-header__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;

  width: 100%;
  max-width: 1200px;

  margin: 0 auto;
  gap: 16px;
}

/* =========================
   LEFT
========================= */

.site-header__left {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.site-header__brand img {
  display: block;
  height: auto;
  max-width: 180px;
}

/* =========================
   CENTER
========================= */

.site-header__center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.site-header__nav {
  display: flex;
  gap: 22px;
}

/* =========================
   RIGHT
========================= */

.site-header__right {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.site-header__actions {
  display: flex;
  align-items: center;
  gap: 14px;
}

/* =========================
   BUTTON
========================= */

.site-header__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 10px 22px;
  border: 2px solid #fff;
  border-radius: 999px;

  color: #fff;
  text-decoration: none;
  font-weight: 700;
}

.site-header__btn-text {
  font-size: 14px;
  white-space: nowrap;
  color: #fff;
}

/* =========================
   ICONS
========================= */

.site-header__profile,
.site-header__hamburger {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* =========================
   SIDEMENU
========================= */

.site-header__side-nav {
  display: flex;
}

/* =========================
   TABLET
========================= */

@media (max-width: 1024px) {

  .site-header__inner {
    max-width: 95%;
    grid-template-columns: 1fr auto;
  }

  .site-header__center {
    display: none;
  }
}

/* =========================
   MOBILE
========================= */

@media (max-width: 740px) {

  .site-header {
    padding: 14px 12px;
  }

  .site-header__inner {
    grid-template-columns: 1fr auto;
    gap: 10px;
  }

  .site-header__center {
    display: none;
  }

  .site-header__btn {
    padding: 8px 14px;
    font-size: 12px;
  }

  .site-header__btn-text {
    font-size: 12px;
  }

  .site-header__brand img {
    max-width: 140px;
  }
}

/* =========================
   LARGE SCREENS
========================= */

@media (min-width: 1600px) {

  .site-header__inner {
    max-width: 1400px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('menu-toggle');

  btn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('toggle-menu'));
  });

  const authLink = document.getElementById('header-auth-link');
  const authText = document.getElementById('header-auth-link-text');

  const authToken = window.localStorage.getItem('auth_token');
  const authUserRaw = window.localStorage.getItem('auth_user');
  const authUser = authUserRaw ? (() => { try { return JSON.parse(authUserRaw); } catch { return null; } })() : null;

  const emailEl = document.getElementById('site-header-user-email');

  if (authToken && authText && authLink) {
    if (emailEl && authUser?.email) {
      emailEl.textContent = authUser.email;
    } else if (emailEl) {
      emailEl.textContent = '';
    }

    const profileWrap = document.getElementById('site-header-profile');
    if (profileWrap) profileWrap.style.display = 'flex';
    if (emailEl && authUser?.email) {
      emailEl.textContent = authUser.email;
    }
    authLink.href = '#';
    authText.textContent = 'Cerrar Sesión';

    authLink.addEventListener('click', async (e) => {
      e.preventDefault();
      try {
fetch(`${window.location.protocol}//${window.location.hostname}:8000/api/v1/logout`,
          {
            method: 'POST',
            headers: {
              'Authorization': `Bearer ${authToken}`,
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({}),
          });
        // logout exitoso
        window.localStorage.removeItem('auth_token');
        window.localStorage.removeItem('auth_user');
        window.location.href = '/';
      } catch (err) {
        window.location.href = '/';
      }
    }, { once: true });
  }
});
</script>