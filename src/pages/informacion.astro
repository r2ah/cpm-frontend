---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/footer_prueba.astro';
import Informacion from '../components/Informacion2.astro';
import MasNoticias from '../components/MasNoticias.astro';
---

<Layout title="Información">

  <section class="hero">

    <div class="hero__bg">
      <img
        src="/Imágenes/Imagen de pantalla de inicio-fondo.jpg"
        alt=""
      />
    </div>

    <div class="hero__overlay"></div>

    <Header />

  </section>

  <section class="content">
    <Informacion />
    <MasNoticias />
   
  </section>

  <Footer />

</Layout>

<style>

.hero {
  position: relative;
  height: 40vh;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
}

.hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.35);
}

.content{
  margin-top:-60px;
  position:relative;
  z-index:10;
}

</style>