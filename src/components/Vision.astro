<style>
/* =========================
   CONTENEDOR PADRE
========================= */

.info-section {
  
  color: #563304;
  width: 100%;
  padding: 60px 0px;
  background: white;
  overflow-x: hidden; /* 🔥 evita scroll lateral */
}

.info-section__inner {
  max-width: 1100px;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

/* =========================
   GRID
========================= */

.about-us__grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 40px;
  align-items: center;
}

/* =========================
   LEFT
========================= */

.about-us__left {
  display: flex;
  flex-direction: column;
  gap: 16px;
  min-width: 0; /* 🔥 evita overflow en grid */
}

.about-us__title {
  margin: 0;
  font-size: clamp(32px, 4vw, 56px);
  font-weight: 750;
  line-height: 1.1;
}

.about-us__text {
  font-size: 16px;
  line-height: 1.7;
  color: rgba(5, 5, 5, 0.8);
  margin: 0;

  /* 🔥 clave para evitar overflow */
  word-wrap: break-word;
  overflow-wrap: break-word;
  max-width: 100%;
}

/* =========================
   RIGHT
========================= */

.about-us__right {
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
}

.about-us__image {
  width: 100%;
  max-width: 420px;
  height: auto;
  border-radius: 16px;
  object-fit: cover;
}

/* =========================
   RESPONSIVE
========================= */

@media (max-width: 860px) {
  .about-us__grid {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .about-us__right {
    margin-top: 20px;
  }

  .about-us__image {
    max-width: 100%;
  }
}
</style>