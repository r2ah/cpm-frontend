---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/footer_prueba.astro';
import UsuarioForm from '../../components/forms/UsuarioForm.astro';
import FormTabs from "../../components/forms/FormTabs.astro";
import TablaConVistas from '../../components/TablaConVistas.astro';
---

<Layout
  title="Form Persona"
  bodyClass="body--light"
>

  <Header />
  <FormTabs/>
  <main class="page">

    <TablaConVistas
      columns={[
        { key: 'col1', header: 'Columna 1' },
        { key: 'col2', header: 'Columna 2' },
        { key: 'col3', header: 'Columna 3' }
      ]}
      rows={[
        { col1: 'Usuario 1', col2: 'Correo 1', col3: 'Rol 1' },
        { col1: 'Usuario 2', col2: 'Correo 2', col3: 'Rol 2' },
        { col1: 'Usuario 3', col2: 'Correo 3', col3: 'Rol 3' }
      ]}
    >
      <UsuarioForm />
    </TablaConVistas>

  </main>

 

</Layout>

<style>

.page {
  min-height: calc(100vh - 120px);
  display: flex;
  justify-content: center;


  padding: 40px 24px;
}

  body {
    background: white;
    color: #111;
  }

</style>