<section class="info-section-about">

  <div class="info-section__inner">

    <!-- ABOUT US -->
    <section class="about-us">

      <div class="about-us__grid">

        <!-- IZQUIERDA -->
        <div class="about-us__left">
          <h2 class="about-us__title">Sobre nosotros</h2>

          <b class="about-us__text">
            El objeto social de la Comisión Provincial de Monumentos de la Oficina del Historiador de La Habana es la preservación, conservación y restauración del patrimonio cultural, histórico y arquitectónico de la ciudad, con especial énfasis en el Centro Histórico y las zonas priorizadas para la conservación. Su misión se centra en proteger los monumentos, edificios y sitios de valor histórico y artístico, además de fomentar la cultura habanera y nacional.
          </b>
        </div>

        <!-- DERECHA -->
        <div class="about-us__right">
          <img
            class="about-us__image"
            src="/assets-1/Mujer 1.2-01.svg"
            alt="Sobre nosotros"
            loading="lazy"
          />
        </div>

      </div>

    </section>

  </div>

</section>

<style>
/* =========================
   CONTENEDOR PADRE
========================= */

.info-section-about {
  border-radius:30px 30px 0 0;
  color:#563304;
  width: 100%;
  padding: 10px 0px;
  background:white; /* aquí puedes cambiar color si quieres */
}

.info-section__inner {
  max-width: 1100px;
  margin: 0 auto;
}

/* =========================
   ABOUT US
========================= */

.about-us__grid {
  display: grid;
  grid-template-columns: 60% 40%;
  gap: 30px;
  align-items: start;
}

/* LEFT */
.about-us__left {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.about-us__title {
  margin: 0;
  font-size: clamp(34px, 5vw, 56px);
  font-weight: 750;
}

.about-us__text {
  font-size: 16px;
  line-height: 1.6;
  color: rgba(5, 5, 5, 0.8);
  margin: 0;
}

/* RIGHT */
.about-us__right {
  display: flex;
  justify-content: center;
}

.about-us__image {
  width: 100%;
  max-width: 420px;
  border-radius: 16px;
}

/* RESPONSIVE */
@media (max-width: 860px) {
  .about-us__grid {
    grid-template-columns: 1fr;
    text-align: center;
  }
}
</style>
