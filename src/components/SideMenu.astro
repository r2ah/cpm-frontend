<aside id="side-menu" class="side-menu">
  <div class="side-menu__header">
    <button id="menu-close" class="side-menu__back">
      ←
    </button>

    <h2>MENÚ</h2>
  </div>

  <div class="side-menu__profile">
    <div class="side-menu__avatar">
        <img
        src="/Identidad/Identidad principal.png"
        alt="Perfil"
      />
    </div>

    <h3>Nombre Usuario</h3>
    <p>usuario@email.com</p>
  </div>

  <nav class="side-menu__nav">
    <a href="/estadisticas">
      <span>📊</span>
      <span>Estadísticas</span>
    </a>

    <a href="#">
      <span>📝</span>
      <span>Formulario</span>
    </a>

    <a href="/informacion">
      <span>ℹ️</span>
      <span>Información</span>
    </a>

    <a href="/about_us">
      <span>🏛️</span>
      <span>Acerca de...</span>
    </a>
  </nav>

  <div class="side-menu__divider"></div>

  <div class="side-menu__settings">
    <h4>AJUSTES</h4>

    <a href="#">
      <span>👤</span>
      <span>Perfil</span>
    </a>

    <a href="#">
      <span>⚙️</span>
      <span>Configuración</span>
    </a>
  </div>
</aside>

<style>
.side-menu {
  position: fixed;
  top: 82px;
  right: -300px;

  width: 300px;
  height: 70vh;

  background: #6b3a00;
  color: white;

  z-index: 45;

  display: flex;
  flex-direction: column;

  transition: right 0.3s ease;

  box-shadow: -8px 0 20px rgba(0, 0, 0, 0.25);

  border-bottom-left-radius: 12px;

  overflow-y: auto;
}

.side-menu.active {
  right: 0;
}

.side-menu__header {
  height: 45px;

  display: flex;
  align-items: center;
  gap: 10px;

  padding: 0 14px;

  background: rgba(0, 0, 0, 0.08);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.side-menu__header h2 {
  margin: 0;
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.side-menu__back {
  background: transparent;
  border: none;
  color: white;
  font-size: 1.2rem;
  cursor: pointer;
}

.side-menu__profile {
  display: flex;
  flex-direction: column;
  align-items: center;

  text-align: center;

  padding: 12px 12px 10px;
}

.side-menu__avatar {
  width: 60px;
  height: 60px;

  border-radius: 50%;
  overflow: hidden;

  margin-bottom: 8px;

  background: rgba(255, 255, 255, 0.12);
}

.side-menu__avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.side-menu__profile h3 {
  margin: 0;
  font-size: 0.95rem;
  font-weight: 600;
}

.side-menu__profile p {
  margin-top: 3px;
  font-size: 0.75rem;
  opacity: 0.8;
}

.side-menu__nav,
.side-menu__settings {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.side-menu__nav a,
.side-menu__settings a {
  display: flex;
  align-items: center;
  justify-content: center;

  gap: 8px;

  width: 100%;

  padding: 6px 0;

  color: white;
  text-decoration: none;

  transition: opacity 0.2s;
}

.side-menu__nav a:hover,
.side-menu__settings a:hover {
  opacity: 0.8;
}

.side-menu__divider {
  width: 70%;
  margin: 12px auto;

  border-top: 1px solid rgba(255, 255, 255, 0.12);
}

.side-menu__settings h4 {
  margin: 0 0 6px;

  text-align: center;

  font-size: 0.7rem;
  letter-spacing: 1px;

  opacity: 0.7;
}

@media (max-width: 768px) {
  .side-menu {
    width: 100%;
    right: -100%;
    height: 60vh;
  }

  .side-menu.active {
    right: 0;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const menu = document.getElementById('side-menu');
  const closeBtn = document.getElementById('menu-close');
  const hamburgerBtn = document.getElementById('menu-toggle');

  function toggleMenu() {
    menu?.classList.toggle('active');
  }

  function closeMenu() {
    menu?.classList.remove('active');
  }

  window.addEventListener('toggle-menu', toggleMenu);

  closeBtn?.addEventListener('click', closeMenu);

  // Cerrar al hacer click fuera
  document.addEventListener('click', (event) => {
    if (!menu) return;

    const target = event.target;

    const clickDentroMenu = menu.contains(target);
    const clickHamburguesa = hamburgerBtn?.contains(target);

    if (!clickDentroMenu && !clickHamburguesa) {
      closeMenu();
    }
  });
});
</script>