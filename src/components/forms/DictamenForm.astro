---
---

<section class="dictamen-page">

  <form class="dictamen-form">

    <!-- DICTAMEN -->
    <div class="form-card">
      <h2 class="form-card__title">Dictamen</h2>

      <div class="form">

        <div class="form__group">
          <label class="form__label">Dirección</label>
          <input class="form__input" type="text" placeholder="Dirección" />
        </div>

        <div class="form__group">
          <label class="form__label">Localización</label>
          <input class="form__input" type="text" placeholder="Localización" />
        </div>

        <div class="form__group">
          <label class="form__label">Proyectista</label>
          <select class="form__input">
            <option>Seleccione...</option>
          </select>
        </div>

        <div class="form__group">
          <label class="form__label">Fecha</label>
          <input class="form__input" type="date" />
        </div>

      </div>
    </div>

    <!-- ESTADOS -->
    <div class="form-card">
      <h2 class="form-card__title">Estado del Proyecto</h2>

      <div class="form">

        <div class="form__group">
          <label class="form__label">Inversionista</label>
          <select class="form__input">
            <option>Seleccione...</option>
          </select>
        </div>

        <div class="form__group">
          <label class="form__label">Contratista</label>
          <select class="form__input">
            <option>Seleccione...</option>
          </select>
        </div>

        <div class="form__group">
          <label class="form__label">Estado</label>
          <select class="form__input">
            <option>Elaborado</option>
            <option>Revisado</option>
            <option>Aprobado</option>
            <option>Denegado</option>
          </select>
        </div>

      </div>
    </div>

    <!-- MEDIOS -->
    <div class="form-card">
      <h2 class="form-card__title">Medios Asociados</h2>

      <div class="form">

        <div class="form__group">
          <input class="form__input" type="text" placeholder="Emisor" />
        </div>

        <div class="form__group">
          <input class="form__input" type="text" placeholder="Localización" />
        </div>

        <div class="form__group">
          <input class="form__input" type="text" placeholder="DUS / Micro" />
        </div>

        <div class="form__group">
          <select class="form__input">
            <option>Intervenciones</option>
          </select>
        </div>

      </div>
    </div>

    <!-- USUARIOS -->
    <div class="form-card">
      <h2 class="form-card__title">Usuarios</h2>

      <div class="form">

        <div class="form__group">
          <label class="form__label">Elaborado por</label>
          <input class="form__input" type="text" />
        </div>

        <div class="form__group">
          <label class="form__label">Aprobado por</label>
          <input class="form__input" type="text" />
        </div>

        <div class="form__group">
          <label class="form__label">Revisado por</label>
          <input class="form__input" type="text" />
        </div>

      </div>
    </div>

    <!-- OBSERVACIONES -->
    <div class="form-card">
      <h2 class="form-card__title">Observaciones</h2>

      <div class="form__group">
        <textarea class="form__input textarea auto-grow"></textarea>
      </div>

      <div class="form__group">
        <textarea class="form__input textarea auto-grow"></textarea>
      </div>
    </div>

    <!-- BOTÓN -->
    <div class="form-card submit-card">
      <button class="btn btn--primary" type="submit">
        Guardar Dictamen
      </button>
    </div>

  </form>

</section>

<script is:inline>
  document.querySelectorAll("textarea.auto-grow").forEach((textarea) => {
    const resize = () => {
      textarea.style.height = "auto";
      textarea.style.height = textarea.scrollHeight + "px";
    };

    textarea.addEventListener("input", resize);
    resize();
  });
</script>

<style>
/* ========================= */
/* 🔥 CENTRADO FORZADO REAL */
/* ========================= */

.dictamen-page {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0px 15px;
  box-sizing: border-box;
}

/* FORM CONTENEDOR */
.dictamen-form {
  width: calc(100% - 30px);
  max-width: 480px;
  margin: 0 auto;

  display: flex;
  flex-direction: column;
  gap: 18px;
}

/* ========================= */
/* CARD (MISMO SISTEMA LOGIN) */
/* ========================= */

.form-card {
  width: 100%;
  padding: 30px;
  border-radius: 20px;

  background: #fff;
  box-shadow: 0 4px 20px #5a3506;

  display: flex;
  flex-direction: column;
  gap: 15px;
  box-sizing: border-box;
}

.form-card__title {
  font-size: 28px;
  font-weight: 400;
  color: #5a3506;
  margin: 0;
}

/* ========================= */
/* FORM SYSTEM */
/* ========================= */

.form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.form__group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form__label {
  font-size: 13px;
  color: #444;
}

/* INPUTS */
.form__input {
  padding: 12px;
  border-radius: 12px;
  border: 1px solid rgba(0,0,0,0.15);
  font-size: 14px;
  outline: none;
  background: #fff;
  width: 100%;
  box-sizing: border-box;
}

/* TEXTAREA */
.textarea {
  min-height: 120px;
  resize: vertical;
}

/* ========================= */
/* BUTTONS */
/* ========================= */

.btn {
  padding: 12px;
  border-radius: 14px;
  border: none;
  cursor: pointer;
  font-weight: 700;
  font-size: 14px;
}

.btn--primary {
  background: #553304;
  color: #fff;
}

.submit-card .btn {
  width: 100%;
}

/* ========================= */
/* RESPONSIVE REAL */
/* ========================= */

@media (max-width: 600px) {
  .dictamen-page {
    padding: 20px 10px;
  }

  .form-card {
    padding: 20px;
  }

  .form-card__title {
    font-size: 22px;
  }

  .form__input {
    font-size: 13px;
    padding: 10px;
  }
}

@media (min-width: 1600px) {
  .dictamen-form {
    width: 460px;
  }
}


</style>