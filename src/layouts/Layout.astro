---
export type Props = {
  title?: string;
  bodyClass?: string;
};

const {
  title = 'SEINA',
  bodyClass = ''
} = Astro.props;
---



<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>

	<body>

		<div class="page">

			<!-- CONTENIDO DINÁMICO -->
			<main class="content">
				<slot />
			</main>

		</div>

		<script>
			(function () {
				if (typeof document === 'undefined') return;

				// NOTE:
				// El menú lateral real del proyecto se controla desde Header.astro/SideMenu.astro
				// con un CustomEvent('toggle-menu') y la clase `active` en #side-menu.
				// Por compatibilidad, este bloque (data-menu-toggle/data-menu) se desactiva
				// para evitar listeners duplicados y comportamientos inconsistentes.
				})();
		</script>

		<style>

			:root {
				--bg: #0b0f19;
				--text: #ffffff;
				--muted: rgba(255, 255, 255, 0.75);
				--brand: #5b7cfa;
				--brand2: #34d399;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial,
					"Apple Color Emoji", "Segoe UI Emoji";
				background: var(--bg);
				color: var(--text);
			}

			/* 🔥 CLAVE DEL STICKY FOOTER */
			html, body {
				height: 100%;
			}

			.page {
				min-height: 100vh;
				display: flex;
				flex-direction: column;
			}

			.content {
				flex: 1;
				display: flex;
				flex-direction: column;
			}

			/* ===== TU HERO ===== */

			

			.btn--ghost:hover {
				background: rgba(255, 255, 255, 0.12);
			}

			@media (max-width: 640px) {
				.hero__content {
					padding-top: 72px;
				}
			}


            

          


		</style>

	</body>
</html>