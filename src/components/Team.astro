---
// Team Section
---

<section class="team">
  <div class="team__inner">

    <h2 class="team__title">Equipo de trabajo</h2>

    <div class="team__grid">

      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 1" />
         <p class="team__role">Presidenta</p>
        <h3 class="team__name">Dra. Arq. Vilma Rodríguez Tápanes</h3>
        
      </article>

      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 2" />
       <p class="team__role">Secretaria Ejecutiva</p> 
       <h3 class="team__name">Arq. Adriana Galup Martínez</h3>
        
      </article>

      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 3" />
       <p class="team__role">Especialista de la Comisión</p> 
       <h3 class="team__name">Arq. Elisa Rodríguez Castillo</h3>
        
      </article>

      <!--
      <article class="team__card">
        <img src="/Elementos gráficos/Ícono de perfil 3-01.svg" alt="Miembro 4" />
         <p class="team__role">Cargo</p>
        <h3 class="team__name">Nombre 4</h3>
       
      </article>
      -->

    </div>

  </div>
</section>

<style>
.team {
  width: 100%;
  padding: 100px 0;
  background: #fff;
}

.team__inner {
  width: 90%;
  max-width: 1800px;
  margin: 0 auto;
}

.team__title {
  text-align: center;
  font-size: clamp(42px, 3vw, 72px);
  margin-bottom: 60px;
  color: #111;
}

/* GRID CENTRADO DINÁMICO */
.team__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, 280px);
  gap: 40px;
  justify-content: center;
}

.team__card {
  width: 100%;
  max-width: 320px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.team__card img {
  width: 100%;
  max-width: 280px;
  height: auto;
  aspect-ratio: 220 / 270;
  object-fit: cover;
  border-radius: 18px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.team__name {
  margin: 0;
  font-size: clamp(18px, 1.2vw, 26px);
  font-weight: 600;
  color: #111;
}

.team__role {
  margin: 0;
  font-size: clamp(14px, 1vw, 18px);
  color: #666;
}

/* Hover suave opcional */
.team__card {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.team__card:hover {
  transform: translateY(-6px);
}

/* Tablet */
@media (max-width: 900px) {
  .team__title {
    font-size: 36px;
  }
}

/* Móvil */
@media (max-width: 500px) {
  .team__title {
    font-size: 32px;
  }
}
</style>