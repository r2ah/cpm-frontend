<section class="carousel">
  <div class="carousel__header">
    <h2>Información</h2>
  </div>

  <div class="carousel__wrapper">

    <div class="carousel__viewport">
      <div class="carousel__track" id="carouselTrack">

        <article class="carousel__card">
          <img src="/Imágenes/imagen 1-02.png" alt="Imagen 1" />
          <div class="carousel__cardBody">
            <h3>Historia </h3>
            <p>Breve reseña sobre la creación de la Comisión y su relación con la Oficina del Historiador.</p>
          </div>
        </article>

        <article class="carousel__card">
          <img src="/Imágenes/imagen 2-02.png" alt="Imagen 2" />
          <div class="carousel__cardBody">
            <h3>Funciones </h3>
            <p> Enumerar tareas principales: evaluación de monumentos, gestión documental, educación patrimonial.</p>
          </div>
        </article>

        <article class="carousel__card">
          <img src="/Imágenes/imagen 3-02.png" alt="Imagen 3" />
          <div class="carousel__cardBody">
            <h3>Ámbito de acción </h3>
            <p> Indicar que trabaja en el Centro Histórico y otros espacios de la provincia</p>
          </div>
        </article>

        <article class="carousel__card">
          <img src="/Imágenes/imagen 4-02.png" alt="Imagen 4" />
          <div class="carousel__cardBody">
            <h3>Proyectos destacados  </h3>
            <p>Ejemplos de restauraciones, digitalización patrimonial o integración de GIS.</p>
          </div>
        </article>

        <article class="carousel__card">
          <img src="/Imágenes/imagen 5-02.png" alt="Imagen 5" />
          <div class="carousel__cardBody">
            <h3>Impacto social  </h3>
            <p>  Cómo contribuye a la identidad cultural y al orgullo ciudadano.</p>
          </div>
        </article>

       <!-- <article class="carousel__card">
          <img src="/Imágenes/imagen 6-02.png" alt="Imagen 6" />
          <div class="carousel__cardBody">
            <h3>Título 6</h3>
            <p>Descripción de la imagen.</p>
          </div>
        </article>-->

      </div>
    </div>

    <div class="carousel__dots">
      <span class="active" data-slide="0"></span>
      <span data-slide="1"></span>
      <span data-slide="2"></span>
      <span data-slide="3"></span>
    </div>

  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const track = document.getElementById("carouselTrack");
    const dots = document.querySelectorAll(".carousel__dots span");
    const cards = document.querySelectorAll(".carousel__card");

    const moveTo = (index) => {
      const card = cards[0];
      if (!card) return;

      const cardRect = card.getBoundingClientRect();
      const nextCardRect = cards[1]?.getBoundingClientRect();

      // calcula gap real si existe segunda card
      let gap = 0;
      if (nextCardRect) {
        gap = nextCardRect.left - cardRect.right;
      }

      const cardWidth = cardRect.width + gap;

      track.style.transform = `translateX(-${index * cardWidth}px)`;

      dots.forEach(dot => dot.classList.remove("active"));
      dots[index].classList.add("active");
    };

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        moveTo(Number(dot.dataset.slide));
      });
    });
  });
</script>

<style>
.carousel {
  width: 100%;
  padding: 80px 0;
  background: #d3a159;
}

.carousel__header {
  width: 90%;
 
  margin: 0 auto 40px;
}

.carousel__header h2 {
  color: white;
  font-size: clamp(42px, 3vw, 72px);
  margin: 0;
  margin-left: 80px;
}

/* =========================
   CONTENEDOR PRINCIPAL
========================= */

.carousel__wrapper {
  width: 90%;
  margin:auto;
}

.carousel__viewport {
  width: 90%;
  
  margin: 0 auto;
  overflow: hidden;
}

.carousel__track {
  display: flex;
  gap:4%;
  transition: transform 0.5s ease;
}

/* =========================
   TARJETAS
========================= */

.carousel__card {
  width: 22%;
  flex-shrink: 0;

  background: white;
  border-radius: 18px;
  overflow: hidden;

  box-shadow: 0 8px 20px rgba(0, 0, 0, .15);
}

.carousel__card img {
  width: 100%;
  height: clamp(220px, 15vw, 320px);
  object-fit: cover;
  display: block;
}

.carousel__cardBody {
  padding: 20px;
  min-height: 120px;
}

.carousel__cardBody h3 {
  margin: 0 0 10px;
  color: #222;
  font-size: clamp(20px, 1.2vw, 28px);
}

.carousel__cardBody p {
  margin: 0;
  color: #666;
  line-height: 1.6;
  font-size: clamp(15px, 0.9vw, 20px);
}

/* =========================
   INDICADORES
========================= */

.carousel__dots {
  display: flex;
  justify-content: center;
  gap: 22px;
  margin-top: 30px;
}

.carousel__dots span {
  width: 70px;
  height: 15px;
  border-radius: 999px;
  background: rgba(255, 255, 255, .35);
  cursor: pointer;
  transition: .3s;
}

.carousel__dots span.active {
  background: white;
}

/* =========================
   TABLET
========================= */

@media (max-width: 1000px) {

  .carousel__viewport {
    width: 95%;
  }

  .carousel__card {
    width: 300px;
  }
}

/* =========================
   MÓVIL
========================= */

@media (max-width: 700px) {

  .carousel__viewport {
    max-width: 300px;
  }

  .carousel__header h2 {
    text-align: center;
    margin-left: 0;
    font-size: 32px;
  }
}
</style>