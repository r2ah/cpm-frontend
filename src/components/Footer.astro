<footer class="site-footer">

  <div class="site-footer__inner">

    <!-- LEFT -->
    <div class="site-footer__col site-footer__col--brand">
      <a href="/" class="site-footer__logo" aria-label="SEINA">
        <img
          src="/Identidad/Identidad secundaria en blanco (barra superior)-01.png"
          alt="SEINA"
          width="140"
          height="36"
          loading="lazy"
        />
      </a>

      <p class="site-footer__text">
        Construyendo experiencias digitales modernas y minimalistas.
      </p>
    </div>

    <!-- CENTER -->
    <div class="site-footer__col">
      <h4 class="site-footer__title">Navegación</h4>
      <a href="/" class="site-footer__link">Inicio</a>
      <a href="/about" class="site-footer__link">Sobre nosotros</a>
      <a href="/services" class="site-footer__link">Servicios</a>
      <a href="/contact" class="site-footer__link">Contacto</a>
    </div>

    <!-- RIGHT -->
    <div class="site-footer__col">
      <h4 class="site-footer__title">Redes</h4>
      <a href="#" class="site-footer__link">Instagram</a>
      <a href="#" class="site-footer__link">Twitter</a>
      <a href="#" class="site-footer__link">LinkedIn</a>
    </div>

  </div>

  <div class="site-footer__bottom">
    <p>© {new Date().getFullYear()} SEINA. Todos los derechos reservados.</p>
  </div>

</footer>

<style>
	.site-footer {
		background: rgba(20, 20, 24, 0.95);
		color: #fff;
		padding: 60px 20px 20px;
		backdrop-filter: blur(10px);
	}

	/* GRID PRINCIPAL */
	.site-footer__inner {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 40px;
		max-width: 1100px;
		margin: 0 auto;
	}

	/* COLUMNAS */
	.site-footer__col {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	/* LOGO */
	.site-footer__logo img {
		display: block;
		max-width: 140px;
		height: auto;
	}

	.site-footer__text {
		font-size: 14px;
		opacity: 0.8;
		line-height: 1.5;
		max-width: 260px;
	}

	/* TITULOS */
	.site-footer__title {
		font-size: 14px;
		margin-bottom: 8px;
		letter-spacing: 0.5px;
		text-transform: uppercase;
		opacity: 0.9;
	}

	/* LINKS */
	.site-footer__link {
		color: rgba(255, 255, 255, 0.75);
		text-decoration: none;
		font-size: 14px;
		transition: 0.2s ease;
	}

	.site-footer__link:hover {
		color: #fff;
		transform: translateX(2px);
	}

	/* BOTTOM BAR */
	.site-footer__bottom {
		margin-top: 40px;
		padding-top: 20px;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		text-align: center;
		font-size: 12px;
		opacity: 0.7;
	}

	/* RESPONSIVE */
	@media (max-width: 768px) {
		.site-footer__inner {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.site-footer__text {
			margin: 0 auto;
		}

		.site-footer__col {
			align-items: center;
		}
	}
</style>