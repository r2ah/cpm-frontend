<style>
/* =========================
   CONTENEDOR PADRE
========================= */

.info-section {
  border-radius:30px 30px 0 0;
  color:#563304;
  width: 100%;
  padding: 10px 0px;
  background:white; /* aquí puedes cambiar color si quieres */
}

.info-section__inner {
  max-width: 1100px;
  margin: 0 auto;
}

/* =========================
   ABOUT US
========================= */

.about-us__grid {
  display: grid;
  grid-template-columns: 60% 40%;
  gap: 30px;
  align-items: start;
}

/* LEFT */
.about-us__left {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.about-us__title {
  margin: 0;
  font-size: clamp(34px, 5vw, 56px);
  font-weight: 750;
}

.about-us__text {
  font-size: 16px;
  line-height: 1.6;
  color: rgba(5, 5, 5, 0.8);
  margin: 0;
}

/* RIGHT */
.about-us__right {
  display: flex;
  justify-content: center;
}

.about-us__image {
  width: 100%;
  max-width: 420px;
  border-radius: 16px;
}

/* RESPONSIVE */
@media (max-width: 860px) {
  .about-us__grid {
    grid-template-columns: 1fr;
    text-align: center;
  }
}
</style>