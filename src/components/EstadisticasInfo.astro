<section class="estadisticas">

  <div class="estadisticas__inner">

    <div class="estadisticas__content">

      <!-- LEFT -->
      <div class="estadisticas__left">

        <h2 class="estadisticas__title">ESTADÍSTICAS</h2>

        <p class="estadisticas__text">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit.
          Sed do eiusmod tempor incididunt ut labore.
        </p>

        <p class="estadisticas__text">
          Ut enim ad minim veniam, quis nostrud exercitation ullamco.
        </p>

      </div>

      <!-- RIGHT -->
      <div class="estadisticas__right">

        <img
          src="/Elementos gráficos/Mujer 2.1-01.svg"
          alt="Estadísticas"
          loading="lazy"
        />

      </div>

    </div>

  </div>

</section>

<style>

/* =========================
   SECCIÓN BASE
========================= */

.estadisticas{
  background:white;
  border-radius:30px 30px 0 0;
  padding:80px 24px;
}

/* CONTENEDOR */
.estadisticas__inner{
  max-width:1200px;
  margin:auto;
}

/* GRID FLEXIBLE */
.estadisticas__content{
  display:grid;
  grid-template-columns: 1.2fr 1fr;
  gap:60px;
  align-items: stretch;
}

/* LEFT */
.estadisticas__left{
  display:flex;
  flex-direction:column;
  justify-content:flex-start;
  gap:20px;
}

/* TITLE */
.estadisticas__title{
  font-size: clamp(40px, 4vw, 64px);
  color:#563304;
  margin:0;
  line-height:1.1;
}

/* TEXT */
.estadisticas__text{
  color:#333;
  line-height:1.8;
  font-size: clamp(16px, 1vw, 20px);
  margin:0;
  max-width:65ch;
}

/* RIGHT */
.estadisticas__right{
  display:flex;
  align-items:center;
  justify-content:center;
}

.estadisticas img{
  width:100%;
  max-width:420px;
  height:auto;
  object-fit:contain;
}

/* =========================
   RESPONSIVE
========================= */

@media (max-width:860px){

  .estadisticas__content{
    grid-template-columns:1fr;
    text-align:center;
    gap:40px;
  }

  .estadisticas__text{
    margin:0 auto;
  }

  .estadisticas img{
    max-width:320px;
  }
}

</style>