---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/footer_prueba.astro';

import EstadisticasInfo from '../components/EstadisticasInfo.astro';
import GraficosPastel from '../components/GraficosPastel.astro';
import GraficoBarras from '../components/GraficoBarras.astro';
---

<Layout title="Estadísticas">

  <section class="hero">

    <div class="hero__bg">
      <img
        src="/Imágenes/Imagen de pantalla de inicio-fondo.jpg"
        alt=""
      />
    </div>

    <div class="hero__overlay"></div>

    <Header />

  </section>

  <div class="content">

    <EstadisticasInfo />

    <GraficosPastel />

    <GraficoBarras />

  </div>

  <Footer />

</Layout>

<style>

.hero {
  position: relative;
  height: 40vh;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
}

.hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.35);
}

.content{
  margin-top:-80px;
  position:relative;
  z-index:10;
}

</style>