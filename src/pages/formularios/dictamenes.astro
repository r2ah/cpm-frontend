---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/footer_prueba.astro';
import DictamenForm from '../../components/forms/DictamenForm.astro';
import FormTabs from "../../components/forms/FormTabs.astro";
import TablaConVistas from '../../components/TablaConVistas.astro';
---

<Layout
  title="Form Dictamen"
  bodyClass="body--light"
>

  <Header />
  <FormTabs/>
  <main class="page">

    <TablaConVistas
      columns={[
        { key: 'col1', header: 'Columna 1' },
        { key: 'col2', header: 'Columna 2' },
        { key: 'col3', header: 'Columna 3' }
      ]}
      rows={[
        { col1: 'Dictamen 1', col2: 'Fecha 1', col3: 'Estado 1' },
        { col1: 'Dictamen 2', col2: 'Fecha 2', col3: 'Estado 2' },
        { col1: 'Dictamen 3', col2: 'Fecha 3', col3: 'Estado 3' }
      ]}
    >
      <DictamenForm />
    </TablaConVistas>

  </main>

 

</Layout>

<style>


.page {
  min-height: calc(100vh - 120px);
  display: flex;
  justify-content: center;
 

  padding: 40px 24px;
}

  body {
    background: white;
    color: #111;
  }

</style>