---
export type Props = {
	title?: string;
};

const { title = 'SEINA' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>

	<body>

		<div class="page">

			<!-- CONTENIDO DINÁMICO -->
			<main class="content">
				<slot />
			</main>

		</div>

		<script>
			(function () {
				if (typeof document === 'undefined') return;

				const toggleBtn = document.querySelector('[data-menu-toggle]');
				const menu = document.querySelector('[data-menu]');
				if (!toggleBtn || !menu) return;

				if (toggleBtn.dataset.menuToggled === '1') return;
				toggleBtn.dataset.menuToggled = '1';

				toggleBtn.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					menu.classList.toggle('is-open');
				});

				document.addEventListener('click', (e) => {
					const target = e.target;
					if (!target) return;

					if (!menu.contains(target) && !toggleBtn.contains(target)) {
						menu.classList.remove('is-open');
					}
				});

				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape') {
						menu.classList.remove('is-open');
					}
				});
			})();
		</script>

		<style>

			:root {
				--bg: #0b0f19;
				--text: #ffffff;
				--muted: rgba(255, 255, 255, 0.75);
				--brand: #5b7cfa;
				--brand2: #34d399;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial,
					"Apple Color Emoji", "Segoe UI Emoji";
				background: var(--bg);
				color: var(--text);
			}

			/* 🔥 CLAVE DEL STICKY FOOTER */
			html, body {
				height: 100%;
			}

			.page {
				min-height: 100vh;
				display: flex;
				flex-direction: column;
			}

			.content {
				flex: 1;
				display: flex;
				flex-direction: column;
			}

			/* ===== TU HERO ===== */

			.hero {
				position: relative;
				min-height: 100vh;
				overflow: hidden;
			}

			.hero__bg {
				position: absolute;
				inset: 0;
				z-index: 0;
			}

			.hero__bg img {
				width: 100%;
				height: 100%;
				object-fit: contain;
				object-position: center;
				filter: saturate(1.05) contrast(1.05);
				opacity: 0.95;
			}

			.hero__bg::after {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(
					180deg,
					rgba(0, 0, 0, 0.55) 0%,
					rgba(0, 0, 0, 0.85) 100%
				);
			}

			.hero__content {
				position: relative;
				z-index: 1;
				max-width: 1100px;
				margin: 0 auto;
				padding: 96px 24px 48px;
				display: flex;
				flex-direction: column;
				gap: 18px;
			}

			.hero__title {
				margin: 0;
				font-size: clamp(40px, 6vw, 72px);
				letter-spacing: -0.02em;
				line-height: 1.05;
			}

			.hero__subtitle {
				margin: 0;
				font-size: clamp(16px, 2vw, 20px);
				color: var(--muted);
				max-width: 52ch;
			}

			.hero__actions {
				margin-top: 12px;
				display: flex;
				gap: 12px;
				flex-wrap: wrap;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 12px 18px;
				border-radius: 12px;
				text-decoration: none;
				color: #0b0f19;
				background: linear-gradient(90deg, var(--brand), var(--brand2));
				font-weight: 700;
			}

			.btn--ghost {
				background: rgba(255, 255, 255, 0.08);
				color: #fff;
				border: 1px solid rgba(255, 255, 255, 0.25);
			}

			.btn--ghost:hover {
				background: rgba(255, 255, 255, 0.12);
			}

			@media (max-width: 640px) {
				.hero__content {
					padding-top: 72px;
				}
			}

		</style>

	</body>
</html>