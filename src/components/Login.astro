---

<section class="login">
  <div class="login__card">
    <h2 class="login__title">Bienvenido</h2>

    <form class="login__form" method="post">
      <div class="field">
        <label class="field__label" for="email">Correo</label>
        <input
          class="field__input"
          id="email"
          name="email"
          type="email"
          placeholder="Ingresa tu correo"
          autocomplete="email"
          required
        />
      </div>

      <div class="field">
        <label class="field__label" for="password">Contraseña</label>
        <input
          class="field__input"
          id="password"
          name="password"
          type="password"
          placeholder="Ingresa tu contraseña"
          autocomplete="current-password"
          required
        />
      </div>

      <div class="login__actions">
        <button class="login__primary" type="submit">
          Registrarse
        </button>

        <button class="login__acceder" type="submit">
          Acceder
        </button>
      </div>
    </form>
  </div>
</section>

<style>
  .login {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 24px;
  }

  .login__card {
    width: min(500px, 90%);
    margin-top: 0;

    background: transparent;
    border: 0;
    border-radius: 0;
    padding: 28px 24px;

    text-align: center;

    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .login__card * {
    position: relative;
    z-index: 1;
  }

  .login__title {
    margin: 0 0 24px;
    font-size: 32px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .login__form {
    width: 100%;

    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .field {
    width: 100%;

    display: flex;
    flex-direction: column;
    gap: 8px;

    text-align: left;
  }

  .field__label {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
  }

  .field__input {
    width: 100%;

    padding: 16px;
    border-radius: 12px;

    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(252, 247, 247, 0.48);

    color: #fff;
    outline: none;

    font-size: 15px;
  }

  .field__input::placeholder {
    color: rgba(255, 255, 255, 0.55);
  }

  .field__input:focus {
    border-color: rgba(91, 124, 250, 0.85);
    box-shadow: 0 0 0 3px rgba(91, 124, 250, 0.25);
  }

  .login__actions {
    width: 100%;

    display: flex;
    justify-content: center;
    gap: 16px;

    margin-top: 12px;
  }

  .login__primary,
  .login__acceder {
    flex: 1;
    max-width: 180px;

    padding: 14px 18px;
    border-radius: 19px;

    border: none;
    cursor: pointer;

    font-weight: 800;
    font-size: 15px;

    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .login__primary {
    background: #553304;
    color: #fff;
  }

  .login__acceder {
    background: #f8f1e7;
    color: #0b0f19;
  }

  .login__primary:hover,
  .login__acceder:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  @media (max-width: 520px) {
    .login__title {
      font-size: 26px;
    }

    .login__actions {
      flex-direction: column;
    }

    .login__primary,
    .login__acceder {
      max-width: none;
      width: 100%;
    }
  }
</style>