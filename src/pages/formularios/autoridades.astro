---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AutoridadForm from '../../components/forms/AutoridadForm.astro';
---

<Layout title="Autoridades">

  <Header />

  <main class="auth-page">

    <AutoridadForm />

  </main>

  <Footer />

</Layout>

<style>

/* 🔥 MISMO CONCEPTO QUE LOGIN */
.auth-page {
  min-height: calc(100vh - 120px);
  display: flex;
  justify-content: center;
  align-items: center;

  padding: 40px 24px;
}

</style>