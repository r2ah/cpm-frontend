---
const tabs = [
  { label: "Personas", href: "/formularios/personas" },
  { label: "Dictamenes", href: "/formularios/dictamenes" },
  { label: "Autoridades", href: "/formularios/autoridades" },
  { label: "Usuarios", href: "/formularios/usuarios" },
  { label: "Intervenciones", href: "/formularios/intervenciones" },
  { label: "Actas", href: "/formularios/actas" }
];
---

<aside id="side-menu" class="side-menu">

  <!-- HEADER -->
  <div class="side-menu__header">
    <button id="menu-close" class="side-menu__back">←</button>
    <h2>MENÚ</h2>
  </div>

  <!-- PROFILE -->
  <div class="side-menu__profile">
    <div class="side-menu__avatar">
      <img src="/Identidad/Identidad principal.png" alt="Perfil" />
    </div>

    <h3>Nombre Usuario</h3>
    <p>usuario@email.com</p>
  </div>

  <!-- NAV -->
  <nav class="side-menu__nav">

    <a href="/estadisticas">
      <span>📊</span>
      <span>Estadísticas</span>
    </a>

    <!-- FORM GROUP -->
    <div class="menu-group">

      <button class="menu-toggle" id="form-toggle">
        <span>📝</span>
        <span>Formulario</span>
      </button>

      <div class="submenu" id="form-submenu">
        {tabs.map((tab) => (
          <a href={tab.href} class="submenu__item">
            {tab.label}
          </a>
        ))}
      </div>

    </div>

    <a href="/informacion">
      <span>ℹ️</span>
      <span>Información</span>
    </a>

    <a href="/about_us">
      <span>🏛️</span>
      <span>Acerca de...</span>
    </a>

  </nav>

  <!-- DIVIDER -->
  <div class="side-menu__divider"></div>

  <!-- SETTINGS -->
  <div class="side-menu__settings">
    <h4>AJUSTES</h4>

    <a href="#">
      <span>👤</span>
      <span>Perfil</span>
    </a>

    <a href="#">
      <span>⚙️</span>
      <span>Configuración</span>
    </a>

  </div>

</aside>

<style>
/* ========================= */
/* BASE FIX */
/* ========================= */

* {
  box-sizing: border-box;
}

.side-menu {
  position: fixed;
  top: 82px;
  right: -300px;

  width: 300px;
  max-width: 100vw;
  height: 70vh;

  background: #6b3a00;
  color: white;

  display: flex;
  flex-direction: column;

  transition: right 0.3s ease;

  box-shadow: -8px 0 20px rgba(0,0,0,0.25);
  border-bottom-left-radius: 12px;

  overflow-x: hidden;
  overflow-y: auto;

  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;
}

.side-menu.active {
  right: 0;
}

/* ========================= */
/* HEADER */
/* ========================= */

.side-menu__header {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;

  height: 48px;

  font-size: 14px;
  font-weight: 600;

  background: rgba(0,0,0,0.08);
}

.side-menu__back {
  position: absolute;
  left: 12px;

  background: transparent;
  border: none;
  color: white;

  font-size: 16px;
  cursor: pointer;
}

/* ========================= */
/* PROFILE (CENTRADO PERFECTO) */
/* ========================= */

.side-menu__profile {
  display: flex;
  flex-direction: column;
  align-items: center;

  text-align: center;

  padding: 14px 10px;
  gap: 4px;
}

.side-menu__avatar {
  width: 58px;
  height: 58px;
  border-radius: 50%;
  overflow: hidden;
}

.side-menu__avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.side-menu__profile h3 {
  font-size: 14px;
  font-weight: 600;
  margin: 0;
}

.side-menu__profile p {
  font-size: 12px;
  margin: 0;
  opacity: 0.8;
}

/* ========================= */
/* NAV CENTER FIX */
/* ========================= */

.side-menu__nav,
.side-menu__settings {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* LINKS UNIFORMES */
.side-menu__nav a,
.side-menu__settings a,
.menu-toggle {
  width: 100%;

  display: flex;
  justify-content: center;
  align-items: center;

  gap: 10px;

  padding: 10px 0;

  font-size: 14px;
  font-weight: 500;

  color: white;
  text-decoration: none;

  background: transparent;
  border: none;
}

/* hover uniforme */
.side-menu__nav a:hover,
.side-menu__settings a:hover,
.menu-toggle:hover {
  background: rgba(255,255,255,0.08);
}

/* ========================= */
/* DIVIDER */
/* ========================= */

.side-menu__divider {
  width: 70%;
  margin: 12px auto;
  border-top: 1px solid rgba(255,255,255,0.12);
}

/* ========================= */
/* SUBMENU CENTRADO */
/* ========================= */

.menu-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submenu {
  display: none;
  flex-direction: column;
  width: 100%;
}

.submenu.active {
  display: flex;
}

.submenu__item {
  text-align: center;
  padding: 8px 0;
  font-size: 13px;
  opacity: 0.9;
}

.submenu__item:hover {
  opacity: 0.7;
}

/* ========================= */
/* SETTINGS TITLE */
/* ========================= */

.side-menu__settings h4 {
  font-size: 11px;
  letter-spacing: 1px;
  opacity: 0.7;
  margin: 8px 0;
  text-align: center;
}

/* ========================= */
/* MOBILE */
/* ========================= */

@media (max-width: 768px) {
  .side-menu {
    width: 100%;
    right: -100%;
    height: 60vh;
  }

  .side-menu.active {
    right: 0;
  }
}

.side-menu {
  position: fixed;
  top: 82px;
  right: -300px;

  width: 300px;
  max-width: 100vw;
  height: 70vh;

  background: #6b3a00;
  color: white;

  display: flex;
  flex-direction: column;

  transition: right 0.3s ease;

  box-shadow: -8px 0 20px rgba(0,0,0,0.25);
  border-bottom-left-radius: 12px;

  overflow-x: hidden;
  overflow-y: auto;

  z-index: 9999; /* 🔥 CLAVE */
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const menu = document.getElementById("side-menu");
  const closeBtn = document.getElementById("menu-close");

  function toggleMenu() {
    menu?.classList.toggle("active");
  }

  function closeMenu() {
    menu?.classList.remove("active");
  }

  window.addEventListener("toggle-menu", toggleMenu);
  closeBtn?.addEventListener("click", closeMenu);

  document.addEventListener("click", (event) => {
    if (!menu) return;

    const target = event.target;
    const inside = menu.contains(target);
    const hamburger = document.getElementById("menu-toggle")?.contains(target);

    if (!inside && !hamburger) closeMenu();
  });

  const formToggle = document.getElementById("form-toggle");
  const formSubmenu = document.getElementById("form-submenu");

  formToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    formSubmenu?.classList.toggle("active");
  });
});
</script>