---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/footer_prueba.astro';
import PersonaForm from '../../components/forms/PersonaForm.astro';
import FormTabs from "../../components/forms/FormTabs.astro";
import TablaConVistas from '../../components/TablaConVistas.astro';
---

<Layout
  title="Form Persona"
  bodyClass="body--light"
>

  <Header />
  <FormTabs/>

  <main class="page">
    <TablaConVistas
      columns={[
        { key: 'col1', header: 'Nombre' },
        { key: 'col2', header: 'Email' },
        { key: 'col3', header: 'Teléfono' },
        { key: 'acciones', header: 'Acciones' }
      ]}
      rows={[]}
    >
      <PersonaForm />
      <pre style="display:none" data-debug>debug</pre>
    </TablaConVistas>
  </main>

</Layout>



<style>
.page {
  min-height: calc(100vh - 120px);
  display: flex;
  justify-content: center;
  padding: 40px 24px;
}

body {
  background: white;
  color: #111;
}
</style>

