---

<footer class="site-footer">

  <div class="site-footer__inner">

    <!-- LEFT (FAQS) -->
    <div class="site-footer__col">
      <h4 class="site-footer__title">FAQ</h4>

      <a href="/faq#que-es" class="site-footer__link">¿Qué es SEINA?</a>
      <a href="/faq#servicios" class="site-footer__link">¿Qué servicios ofrecen?</a>
      <a href="/faq#tiempos" class="site-footer__link">Tiempos de entrega</a>
      <a href="/faq#contacto" class="site-footer__link">Soporte y contacto</a>
    </div>

    <!-- CENTER (LOGO) -->
    <div class="site-footer__col site-footer__col--brand">
      <a href="/" class="site-footer__logo" aria-label="SEINA">
        <img
          src="/Identidad/Identidad principal (footer)-01.png"
          alt="SEINA"
          width="140"
          height="196"
          loading="lazy"
        />
      </a>

      <p class="site-footer__text">
        Construyendo experiencias digitales modernas y minimalistas.
      </p>
    </div>

    <!-- RIGHT (REDES EN FILA) -->
    <div class="site-footer__col">
      <h4 class="site-footer__title">Redes sociales</h4>

      <div class="site-footer__socials">
        <a href="#" class="site-footer__link">Instagram</a>
        <a href="#" class="site-footer__link">Twitter</a>
        <a href="#" class="site-footer__link">LinkedIn</a>
        <a href="#" class="site-footer__link">GitHub</a>
      </div>
    </div>

  </div>

  <div class="site-footer__bottom">
    <p>© {new Date().getFullYear()} SEINA. Todos los derechos reservados.</p>
  </div>

</footer>

<style>
	.site-footer {
		background:#563304;
		color: #fff;
		padding: 60px 20px 20px;
		backdrop-filter: blur(10px);
	}

	/* 3 COLUMNAS */
	.site-footer__inner {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 60px;
		max-width: 1100px;
		margin: 0 auto;
		align-items: start;
		text-align: center;
	}

	/* COLUMNAS */
	.site-footer__col {
		display: flex;
		flex-direction: column;
		gap: 10px;
		align-items: center;
	}

	/* LOGO */
	.site-footer__logo img {
		display: block;
		max-width: 140px;
		height: auto;
	}

	.site-footer__text {
		font-size: 14px;
		opacity: 0.8;
		line-height: 1.5;
		max-width: 260px;
	}

	/* TITULOS */
	.site-footer__title {
		font-size: 14px;
		margin-bottom: 8px;
		letter-spacing: 0.5px;
		text-transform: uppercase;
		opacity: 0.9;
	}

	/* LINKS */
	.site-footer__link {
		color: rgba(255, 255, 255, 0.75);
		text-decoration: none;
		font-size: 14px;
		transition: 0.2s ease;
	}

	.site-footer__link:hover {
		color: #fff;
		transform: translateX(2px);
	}

	/* REDES EN FILA */
	.site-footer__socials {
		display: flex;
		gap: 15px;
		flex-wrap: wrap;
		justify-content: center;
	}

	/* FOOTER BOTTOM */
	.site-footer__bottom {
		margin-top: 40px;
		padding-top: 20px;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		text-align: center;
		font-size: 12px;
		opacity: 0.7;
	}

	/* RESPONSIVE */
	@media (max-width: 768px) {
		.site-footer__inner {
			grid-template-columns: 1fr;
			gap: 40px;
		}
	}
</style>