---
---

<section class="login">

  <div class="login__card">

    <!-- LOGO -->
    <a class="login__logo" href="/" aria-label="SEINA">
      <img
        src="/Identidad/Identidad principal en blanco.png"
        alt="SEINA"
        width="240"
        height="180"
        loading="eager"
      />
    </a>

    <h2 class="login__title">Bienvenido</h2>

    <form class="login__form" method="post">

      <div class="field">
        <input
          class="field__input"
          type="email"
          placeholder="Correo"
          autocomplete="email"
          required
        />
      </div>

      <div class="field">
        <input
          class="field__input"
          type="password"
          placeholder="Contraseña"
          autocomplete="current-password"
          required
        />
      </div>

      <div class="login__actions">
        <button class="login__primary" type="submit">
          Registrarse
        </button>

        <button class="login__acceder" type="submit">
          Acceder
        </button>
      </div>

    </form>

  </div>

</section>

<style>

/* 🔥 GLOBAL FIX (clave para evitar desplazamientos raros) */
* {
  box-sizing: border-box;
}

/* CONTENEDOR GENERAL */
.login {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 24px;
}

/* CARD */
.login__card {
  width: min(400px, 85%);
  text-align: center;
  padding-top:30px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* LOGO */
.login__logo {
  margin-bottom: 10px;
  display: inline-block;
}

/* TITULO */
.login__title {
  margin: 0 0 24px;
  font-size: 48px;
  font-weight: 400;
  color: #fff;
}

/* FORM */
.login__form {
  width: 100%;
  display: flex;
  flex-direction: column;

  gap: 18px;
  align-items: stretch; /* 🔥 clave para alineación perfecta */
}

/* FIELD */
.field {
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* INPUTS */
.field__input {
  width: 100%;
  display: block;

  padding: 12px;
  border-radius: 12px;

  border: 1px solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.95);

  color: #111;
  font-size: 15px;
  outline: none;
}

.field__input::placeholder {
  color: rgba(0, 0, 0, 0.5);
  font-size: 25px;
  font-style: italic;
  letter-spacing: 0.2px;
}

/* BOTONES */
.login__actions {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-top: 12px;
  width: 100%;
}

.login__primary,
.login__acceder {
  flex: 1;
  max-width: 180px;

  padding: 14px 18px;
  border-radius: 19px;
  border: none;
  cursor: pointer;

  font-weight: 800;
  font-size: 15px;
}

/* COLORES */
.login__primary {
  background: #553304;
  color: #fff;
}

.login__acceder {
  background: #f8f1e7;
  color: #0b0f19;
}

/* RESPONSIVE */
@media (max-width: 520px) {
  .login__actions {
    flex-direction: column;
  }

  .login__primary,
  .login__acceder {
    max-width: none;
    width: 100%;
  }
}

</style>