</footer>

<style>
.site-footer {
  background: #563304;
  color: #fff;
  padding: 80px 20px 30px;
}

/* GRID CENTRADO INTELIGENTE */
.site-footer__inner {
  width: 90%;
  max-width: 1800px;
  margin: 0 auto;

  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 60px;

  justify-items: center;
  text-align: center;
}

/* COLUMNAS */
.site-footer__col {
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
}

/* TITULOS */
.site-footer__title {
  font-size: clamp(16px, 1vw, 22px);
  margin-bottom: 10px;
  text-transform: uppercase;
  opacity: 0.9;
}

/* LOGO */
.site-footer__logo img {
  width: clamp(140px, 10vw, 220px);
  height: auto;
}

/* TEXTO */
.site-footer__text {
  font-size: clamp(14px, 0.9vw, 18px);
  opacity: 0.8;
  line-height: 1.6;
  max-width: 320px;
}

/* LINKS */
.site-footer__link {
  color: rgba(255,255,255,.75);
  text-decoration: none;
  font-size: clamp(14px, 0.9vw, 18px);
  transition: 0.2s ease;
}

.site-footer__link:hover {
  color: #fff;
  transform: translateY(-2px);
}

/* REDES */
.site-footer__socials {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

.site-footer__social {
  color: rgba(255,255,255,.75);
  text-decoration: none;
  transition: 0.2s ease;
}

.site-footer__social:hover {
  color: #fff;
}

/* BOTTOM */
.site-footer__bottom {
  margin-top: 50px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,.1);
  text-align: center;
  font-size: clamp(12px, 0.8vw, 16px);
  opacity: 0.7;
}

.site-footer__social {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: rgba(255,255,255,0.08);
  transition: 0.2s ease;
}

.site-footer__social:hover {
  background: rgba(255,255,255,0.18);
  transform: translateY(-3px);
}

.icon {
  width: 20px;
  height: 20px;
  fill: white;
}

/* RESPONSIVE */
@media (max-width: 768px) {
  .site-footer__inner {
    gap: 40px;
  }
}
</style>