<section class="form-card">

  <h2 class="form-card__title">Intervenciones</h2>

  <form class="form" id="intervention-form">

  <div class="form__group">
    <label class="form__label">Nombre</label>
    <input name="name" class="form__input" type="text" required />
  </div>

  <div class="form__group">
    <label class="form__label">Intervención Superior</label>
    <select name="parent_id" class="form__input">
      <option value="">Ninguna</option>
    </select>
  </div>

  <button class="btn btn--primary" type="submit">
    Guardar
  </button>

  <p id="status"></p>

</form>

</section>


<script type="module">
const BASE = "http://localhost:8000";

const form = document.getElementById("intervention-form");
const status = document.getElementById("status");
const select = form.querySelector("select[name='parent_id']");

// cargar intervenciones para el select
async function loadParents() {
  const res = await fetch(`${BASE}/api/v1/interventions`);
  const json = await res.json();

  const data = json.data || [];

  select.innerHTML = `<option value="">Ninguna</option>`;

  data.forEach(item => {
    const opt = document.createElement("option");
    opt.value = item.id;
    opt.textContent = item.name;
    select.appendChild(opt);
  });
}

loadParents();

form.addEventListener("submit", async (e) => {
  e.preventDefault();

  const fd = new FormData(form);

  const payload = {
    name: fd.get("name"),
    parent_id: fd.get("parent_id") || null
  };

  try {
    status.textContent = "Guardando...";

    const res = await fetch(`${BASE}/api/interventions`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(payload)
    });

    const data = await res.json();

    if (!res.ok) throw new Error(data.message || "Error");

    status.textContent = "Guardado ✔️";

    form.reset();
    loadParents();

  } catch (err) {
    status.textContent = err.message;
  }
});
</script>


