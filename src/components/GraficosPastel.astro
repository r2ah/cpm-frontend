<style>

.pasteles{
  background:#d9c099;
  padding:80px 24px;
}

.pasteles__inner{
  max-width:1100px;
  margin:auto;
}

.pasteles h2{
  text-align:center;
  color:#563304;
  margin-bottom:50px;
}

.pasteles__grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:30px;
}

.pastel{
  text-align:center;
}

/* =========================
   CÍRCULO (GRÁFICO)
========================= */
.pastel__circle{
  width:140px;
  height:140px;
  margin:auto;
  border-radius:50%;

  /* borde blanco exterior */
  padding:10px;
  background:white;

  display:flex;
  justify-content:center;
  align-items:center;

  position:relative;
}

/* gráfico real */
.pastel__circle::before{
  content:"";
  position:absolute;
  inset:10px;
  border-radius:50%;

  background: conic-gradient(
    #563304 0 calc(var(--value) * 1%),
    #e0b878ff calc(var(--value) * 1%) 100%
  );
}

/* círculo interior */
.pastel__circle span{
  position:relative;
  width:105px;
  height:105px;

  background:white;
  border-radius:50%;

  display:flex;
  justify-content:center;
  align-items:center;

  font-weight:700;
  font-size:18px;
  color:#563304;
}

/* texto */
.pastel h3{
  margin-top:15px;
  font-weight:700;
  color:#000;
}

/* responsive */
@media (max-width:860px){
  .pasteles__grid{
    grid-template-columns:repeat(2,1fr);
  }
}

</style>